{
  "version": "1.0.0",
  "packageManager": "pnpm@8.15.0",
  "scripts": {
    "sukit": "node packages/cli/bin/sukit.js",
    "sukit:dev": "node packages/cli/bin/sukit.js dev",
    "sukit:build": "node packages/cli/bin/sukit.js build",
    "sukit:ddev": "pnpx nodemon --watch apps --watch packages --ext ts,tsx,js,jsx,json,tsx,css --exec \"pnpm dev:watch\"",
    "sukit:export": "node packages/cli/bin/sukit.js export",
    "sukit:new": "node packages/cli/bin/sukit.js new",
    "dev": "pnpm dev:watch",
    "dev:web": "pnpm --filter sukit-web dev",
    "dev:server": "pnpm --filter @sukit/server dev",
    "dev:watch": "concurrently -n web,server -c cyan,green \"pnpm dev:web\" \"pnpm dev:server\"",
    "build": "turbo run build",
    "start": "turbo run start",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "setup": "bash scripts/setup.sh",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:push": "turbo run db:push",
    "db:studio": "turbo run db:studio",
    "db:seed": "turbo run db:seed",
    "db:seed:marketplace": "tsx packages/marketplace/prisma/seed.ts",
    "export": "turbo run export",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "dev:daemon": "pm2 start ecosystem.config.cjs && pm2 logs",
    "dev:daemon:stop": "pm2 stop ecosystem.config.cjs && pm2 delete ecosystem.config.cjs",
    "dev:daemon:status": "pm2 status",
    "modules:install": "node scripts/module-install.mjs",
    "modules:build": "turbo run build --filter=./modules/*",
    "modules:link": "node scripts/link-modules.mjs",
    "prepare": "husky"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "concurrently": "^10.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "pm2": "^7.0.1",
    "prettier": "^3.0.0",
    "prisma": "^6.0.0",
    "tsx": "^4.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "ioredis": "5.11.0"
  }
}
