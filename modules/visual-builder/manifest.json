{
  "id": "@sukit/visual-builder",
  "name": "Visual Builder",
  "version": "1.0.0",
  "description": "Drag-and-drop page builder with canvas, block library, and property panel",
  "author": {
    "name": "SUKIT Core Team",
    "email": "core@sukit.dev"
  },
  "license": "MIT",
  "icon": "LayoutDashboard",
  "sukit": {
    "minVersion": "1.0.0",
    "maxVersion": "2.0.0",
    "capabilities": [
      "ui:canvas", "ui:sidebar", "ui:toolbar", "blocks:register"
    ],
    "permissions": [
      "db:read", "db:write"
    ],
    "entrypoints": {
      "main": "./dist/index.js",
      "styles": "./dist/styles.css"
    },
    "slots": {
      "canvas:main": {
        "component": "./dist/canvas/Canvas.jsx",
        "position": 0
      },
      "sidebar:left": {
        "component": "./dist/components/block-palette.jsx",
        "position": 10
      },
      "sidebar:right": {
        "component": "./dist/components/property-panel.jsx",
        "position": 10,
        "when": "context.selectedBlock !== null"
      },
      "toolbar:top": {
        "component": "./dist/components/builder-toolbar.jsx",
        "position": 5
      }
    },
    "hooks": {
      "page:beforeSave": "./dist/hooks/beforeSave.js",
      "page:afterSave": "./dist/hooks/afterSave.js"
    },
    "api": {
      "basePath": "/api/builder",
      "routes": "./dist/routes.js"
    },
    "dependencies": {
      "@sukit/core": "^1.0.0",
      "@sukit/ui": "^1.0.0"
    },
    "peerDependencies": {
      "react": "^19.0.0",
      "next": "^16.0.0",
      "@dnd-kit/core": "^6.0.0",
      "@dnd-kit/sortable": "^10.0.0"
    }
  }
}
