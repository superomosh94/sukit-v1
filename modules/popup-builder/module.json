{
  "id": "@sukit/module-popup-builder",
  "name": "Popup Builder",
  "version": "1.0.0",
  "description": "Create popups, modals, slide-ins, and floating bars with triggers, animations, and analytics",
  "author": "SUKIT Team",
  "license": "MIT",
  "icon": "Popcorn",
  "minAppVersion": "1.0.0",
  "category": "marketing",
  "features": [
    "popup-types", "triggers", "display-rules", "animations",
    "scheduling", "analytics", "ab-testing", "pre-built-templates"
  ],
  "settings": {
    "defaultAnimation": {
      "type": "select",
      "label": "Default Animation",
      "default": "fade",
      "options": [
        { "label": "Fade", "value": "fade" },
        { "label": "Slide Up", "value": "slide-up" },
        { "label": "Slide Down", "value": "slide-down" },
        { "label": "Zoom", "value": "zoom" },
        { "label": "Bounce", "value": "bounce" }
      ]
    },
    "defaultAnimationDuration": {
      "type": "number",
      "label": "Animation Duration (ms)",
      "default": 300
    },
    "enableAnalytics": {
      "type": "boolean",
      "label": "Enable Analytics",
      "default": true
    }
  },
  "popupTypes": ["modal", "slide-in", "floating-bar", "fullscreen", "notification", "inline"],
  "triggers": ["time", "scroll", "exit-intent", "click", "inactivity", "page-views", "element-visibility", "on-load"],
  "animations": ["fade", "slide-up", "slide-down", "slide-left", "slide-right", "zoom", "bounce", "flip", "rotate"]
}
