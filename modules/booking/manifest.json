{
  "id": "@sukit/booking",
  "name": "Booking",
  "version": "1.0.0",
  "description": "Complete booking and reservation system with calendar, staff management, payments, reminders, and analytics",
  "author": { "name": "SUKIT Core Team" },
  "license": "MIT",
  "icon": "CalendarCheck",
  "sukit": {
    "minVersion": "1.0.0",
    "capabilities": ["ui:sidebar", "api:routes", "hooks:page"],
    "permissions": ["database:read", "database:write"],
    "entrypoints": { "main": "./dist/index.js" },
    "api": { "basePath": "/api/booking", "routes": "./dist/routes.js" },
    "dependencies": { "@sukit/core": "^1.0.0" },
    "peerDependencies": { "react": "^19.0.0" }
  }
}
