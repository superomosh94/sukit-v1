  deletedBy String
  deletedAt DateTime @default(now())
  expiresAt DateTime

  @@map("trash_items")
}

// =============================================================================
// LAYER 5: MARKETPLACE ECOSYSTEM
// =============================================================================

enum MarketplaceModuleStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  DEPRECATED
  SUSPENDED

  @@map("marketplace_module_status")
}

model MarketplaceModule {
  id          String @id @default(cuid())
  moduleId    String @unique
  name        String
  description String
  version     String
  authorId    String
  authorName  String

  category String
  tags     String[]

  price                    Float?
  priceModel               String @default("free")
  subscriptionPriceMonthly Float?
  subscriptionPriceYearly  Float?

  downloads   Int   @default(0)
  rating      Float @default(0)
  ratingCount Int   @default(0)

  screenshots String[]
  icon        String?
  banner      String?

  documentation String?
  changelog     String?

  minSukitVersion       String   @default("1.0.0")
  maxSukitVersion       String?
  sukCompatibleVersions String[] @default(["1.0.0"])

  dependencies Json?
  permissions  String[]

  status          String  @default("draft")
  rejectionReason String?

  demoUrl    String?
  supportUrl String?
  sourceUrl  String?

  featured      Boolean   @default(false)
  featuredUntil DateTime?
  staffPick     Boolean   @default(false)
  trendingScore Float     @default(0)

  metadata Json?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  versions          ModuleVersion[]
  reviews           ModuleReview[]
  supportTickets    SupportTicket[]
  installs          ModuleInstall[]
  transactions      Transaction[]
  subscriptions     Subscription[]
  licenses          License[]
  submissionReviews SubmissionReview[]
  analyticsEvents   AnalyticsEvent[]
  developer         Developer?         @relation(fields: [developerId], references: [id])
  developerId       String?

  @@index([status, publishedAt])
  @@index([category, status])
  @@index([featured, status])
  @@index([downloads])
  @@index([rating])
  @@index([trendingScore])
  @@map("marketplace_modules")
}

model ModuleVersion {
  id       String            @id @default(cuid())
  moduleId String
  module   MarketplaceModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  version     String
  changelog   String?
  downloadUrl String
  fileSize    Int     @default(0)
  fileHash    String?
  sukVersion  String

  isLatest      Boolean @default(false)
  isDeprecated  Boolean @default(false)
  isSecurityFix Boolean @default(false)
  isBeta        Boolean @default(false)

  downloads     Int   @default(0)
  compatibility Json?

  createdAt DateTime @default(now())

  @@unique([moduleId, version])
  @@index([moduleId, isLatest])
  @@map("module_versions")
}

model ModuleInstall {
  id       String            @id @default(cuid())
  moduleId String
  module   MarketplaceModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  userId   String
  siteId   String?

  version         String
  previousVersion String?
  status          String  @default("installed")
  autoUpdate      Boolean @default(false)
  pinnedVersion   String?
  channel         String  @default("stable")
  installPath     String?

  installedAt   DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  uninstalledAt DateTime?

  @@index([userId, status])
  @@index([moduleId])
  @@index([siteId])
  @@map("module_installs")
}

model ModuleReview {
  id       String            @id @default(cuid())
  moduleId String
  module   MarketplaceModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  userId   String
  userName String

  rating Int
  title  String?
  review String
  pros   String?
  cons   String?

  versionUsed  String?
  sukitVersion String?

  verified   Boolean @default(false)
  helpful    Int     @default(0)
  notHelpful Int     @default(0)

  status        String  @default("approved")
  moderatorNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  responses ReviewResponse[]

  @@index([moduleId, status, createdAt])
  @@index([userId])
  @@map("module_reviews")
}

model ReviewResponse {
  id         String       @id @default(cuid())
  reviewId   String
  review     ModuleReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  authorId   String
  authorType String       @default("developer")
  response   String

  createdAt DateTime @default(now())

  @@index([reviewId])
  @@map("review_responses")
}

model Developer {
  id          String  @id @default(cuid())
  userId      String  @unique
  email       String
  name        String
  companyName String?
  website     String?
  bio         String?
  avatar      String?

  taxId          String?
  payoutMethod   String?
  payoutEmail    String?
  payoutCountry  String?
  totalEarnings  Float   @default(0)
  unpaidEarnings Float   @default(0)

  status            String    @default("pending")
  approvedAt        DateTime?
  agreementAccepted Boolean   @default(false)
  agreementVersion  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  modules MarketplaceModule[]
  apiKeys DeveloperApiKey[]

  @@index([status])
  @@map("developers")
}

model DeveloperApiKey {
  id          String    @id @default(cuid())
  developerId String
  developer   Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)

  name        String
  key         String   @unique
  keyHash     String?
  permissions String[]
  ipWhitelist String[]
  rateLimit   Int      @default(100)

  lastUsed  DateTime?
  expiresAt DateTime?

  createdAt DateTime  @default(now())
  revokedAt DateTime?

  @@index([developerId])
  @@map("developer_api_keys")
}

model SubmissionReview {
  id         String            @id @default(cuid())
  moduleId   String
  module     MarketplaceModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  reviewerId String

  status            String  @default("pending")
  notes             String?
  validationResults Json?

  createdAt  DateTime  @default(now())
  reviewedAt DateTime?

  @@index([status])
  @@index([moduleId])
  @@map("submission_reviews")
}

model SupportTicket {
  id        String            @id @default(cuid())
  moduleId  String
  module    MarketplaceModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  userId    String
  userName  String
  userEmail String

  subject    String
  message    String
  priority   String  @default("normal")
  status     String  @default("open")
  category   String  @default("question")
  assignedTo String?

  attachments String[]
  metadata    Json?

  resolvedAt   DateTime?
  closedAt     DateTime?
  satisfaction Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  responses TicketResponse[]

  @@index([userId, status])
  @@index([moduleId, status])
  @@index([assignedTo, status])
  @@map("support_tickets")
}

model TicketResponse {
  id          String        @id @default(cuid())
  ticketId    String
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId    String
  authorType  String
  authorName  String?
  message     String
  attachments String[]
  privateNote String?

  createdAt DateTime @default(now())

  @@index([ticketId, createdAt])
  @@map("ticket_responses")
}

model Transaction {
  id         String            @id @default(cuid())
  moduleId   String
  module     MarketplaceModule @relation(fields: [moduleId], references: [id])
  buyerId    String
  buyerName  String
  buyerEmail String

  amount          Float
  currency        String @default("USD")
  fee             Float  @default(0)
  developerAmount Float  @default(0)

  paymentMethod String
  paymentId     String
  type          String @default("purchase")
  status        String @default("pending")

  licenseKey String?
  invoiceUrl String?
  receiptUrl String?

  refundedAt   DateTime?
  refundAmount Float?
  refundReason String?

  metadata Json?

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([buyerId, status, createdAt])
  @@index([moduleId, status, createdAt])
  @@map("transactions")
}

model Subscription {
  id          String            @id @default(cuid())
  moduleId    String
  module      MarketplaceModule @relation(fields: [moduleId], references: [id])
  userId      String
  userEmail   String?
  developerId String?

  plan   String @default("monthly")
  status String @default("active")

  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean   @default(false)
  canceledAt         DateTime?
  pausedAt           DateTime?
  resumedAt          DateTime?

  paymentMethod         String?
  gatewayId             String?
  gatewayCustomerId     String?
  gatewaySubscriptionId String?

  amount   Float  @default(0)
  currency String @default("USD")

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([moduleId, status])
  @@map("subscriptions")
}

model License {
  id            String            @id @default(cuid())
  key           String            @unique
  moduleId      String
  module        MarketplaceModule @relation(fields: [moduleId], references: [id])
  userId        String
  transactionId String?

  status         String   @default("active")
  domains        String[]
  maxActivations Int      @default(3)

  activatedAt   DateTime?
  expiresAt     DateTime?
  revokedAt     DateTime?
  revokedReason String?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([moduleId])
  @@map("licenses")
}

model KnowledgeBaseArticle {
