  folder   MediaFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  tags      MediaAssetTag[]
  favorites MediaFavorite[]

  variants MediaVariant[]

  uploadedBy String
  uploadedAt DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  trashedAt  DateTime?

  metadata Json?

  @@unique([siteId, filename])
  @@map("media_assets")
}

model MediaVariant {
