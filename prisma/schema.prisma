  file      String
  size      Int      @default(0)
  type      String   @default("manual")
  status    String   @default("completed")
  createdBy String
  createdAt DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId])
  @@map("backups")
}

model Webhook {
