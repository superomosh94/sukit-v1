  commentCount  Int        @default(0)
  siteId        String
  authorId      String
  publishedAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  site       Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)
