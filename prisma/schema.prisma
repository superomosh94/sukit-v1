  siteId          String
  name            String
  url             String
  events          Json      @default("[]")
  secret          String?
  active          Boolean   @default(true)
  lastTriggeredAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

