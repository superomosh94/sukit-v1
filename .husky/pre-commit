# Detect package manager
if command -v pnpm >/dev/null 2>&1; then
  PM="pnpm"
elif command -v npm >/dev/null 2>&1; then
  PM="npm"
else
  echo "Error: Neither pnpm nor npm found"
  exit 1
fi

echo "--- Pre-commit checks ---"

echo "[1/3] Typecheck..."
$PM run typecheck
if [ $? -ne 0 ]; then
  echo "ERROR: Typecheck failed. Fix errors above before committing."
  exit 1
fi

echo "[2/3] Lint..."
$PM run lint
if [ $? -ne 0 ]; then
  echo "ERROR: Lint failed. Fix errors above before committing."
  exit 1
fi

echo "[3/3] Build..."
$PM run build
if [ $? -ne 0 ]; then
  echo "ERROR: Build failed. Fix errors above before committing."
  exit 1
fi

echo "--- All checks passed ---"
