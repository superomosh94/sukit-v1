# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://sukite:password@localhost:5432/sukit"
DIRECT_URL="postgresql://sukite:password@localhost:5432/sukit"

# ============================================
# AUTHENTICATION (NextAuth.js)
# ============================================
NEXTAUTH_SECRET="your-secret-key-here-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# OAuth Providers (optional)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ============================================
# FILE STORAGE
# ============================================
STORAGE_TYPE="local"  # local, s3, r2
STORAGE_PATH="./storage"  # for local storage

# S3/R2 Configuration (if STORAGE_TYPE is s3 or r2)
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME="sukit-media"
S3_REGION="us-east-1"
S3_ENDPOINT=""  # for R2: https://<account-id>.r2.cloudflarestorage.com

# ============================================
# REDIS (Caching, Queues, Sessions)
# ============================================
REDIS_URL="redis://localhost:6379"
REDIS_TOKEN=""  # if Redis requires authentication

# ============================================
# EMAIL
# ============================================
EMAIL_PROVIDER="resend"  # resend, smtp
RESEND_API_KEY=""

# SMTP (if EMAIL_PROVIDER is smtp)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="noreply@sukit.dev"

# ============================================
# AI CHAT MODULE (optional)
# ============================================
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4-turbo"
OLLAMA_BASE_URL="http://localhost:11434"  # for local models

# ============================================
# GITHUB INTEGRATION (for deployment)
# ============================================
GITHUB_APP_ID=""
GITHUB_PRIVATE_KEY=""
GITHUB_WEBHOOK_SECRET=""

# ============================================
# EXPORT & DEPLOYMENT
# ============================================
EXPORT_PATH="./exports"
MAX_EXPORT_SIZE_MB=100

# ============================================
# MODULE SYSTEM
# ============================================
MODULES_PATH="./modules"
ALLOWED_MODULES="sukit-chat,sukit-payments,sukit-seo"
MODULE_MARKETPLACE_URL="https://marketplace.sukit.dev"

# ============================================
# SECURITY
# ============================================
ENCRYPTION_KEY="32-character-encryption-key"
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000
CORS_ORIGINS="http://localhost:3000,https://app.sukit.dev"

# ============================================
# LOGGING
# ============================================
LOG_LEVEL="info"  # debug, info, warn, error
LOG_FORMAT="json"  # json, pretty

# ============================================
# PERFORMANCE
# ============================================
CACHE_TTL_SECONDS=3600
CDN_URL=""  # if using CDN for media

# ============================================
# DEVELOPMENT
# ============================================
NODE_ENV="development"
PORT=3000
HOST="0.0.0.0"
