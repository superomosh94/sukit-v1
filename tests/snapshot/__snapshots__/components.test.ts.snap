          <p>Column 3</p>
        </div>
      </div>
    </div>
  </div>
</section>
`;

exports[`PageSettings renders SEO meta tags 1`] = `
<head>
  <title>My Page - SUKIT</title>
  <meta name="description" content="A sample page description" />
  <meta name="keywords" content="sukit, builder, sites" />
  <meta property="og:title" content="My Page" />
  <meta property="og:description" content="A sample page description" />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="My Page" />
  <meta name="twitter:description" content="A sample page description" />
</head>
`;

exports[`MediaLibrary renders media grid 1`] = `
<div class="media-library">
  <div class="media-toolbar">
    <input type="search" placeholder="Search media..." class="media-search" />
    <button class="btn btn-primary upload-btn">Upload</button>
  </div>
  <div class="media-grid">
    <div class="media-item" data-id="media-1">
      <img src="https://images.sukit.dev/photo-1.jpg" alt="Photo 1" />
      <span class="media-name">photo-1.jpg</span>
    </div>
    <div class="media-item" data-id="media-2">
      <img src="https://images.sukit.dev/photo-2.jpg" alt="Photo 2" />
      <span class="media-name">photo-2.jpg</span>
    </div>
  </div>
</div>
`;
