exports[`SiteHeader renders header with logo and navigation 1`] = `
<header class="site-header">
  <div class="header-inner">
    <a class="logo" href="/">
      <img src="/logo.svg" alt="SUKIT" width="120" height="32" />
    </a>
    <nav class="main-nav">
      <a href="/features">Features</a>
      <a href="/pricing">Pricing</a>
      <a href="/docs">Docs</a>
      <a href="/blog">Blog</a>
    </nav>
    <div class="header-actions">
      <a class="btn btn-secondary" href="/login">Sign In</a>
      <a class="btn btn-primary" href="/signup">Get Started</a>
    </div>
  </div>
</header>
`;

exports[`SiteFooter renders footer with links 1`] = `
<footer class="site-footer">
  <div class="footer-grid">
    <div class="footer-column">
      <h4>Product</h4>
      <a href="/features">Features</a>
      <a href="/pricing">Pricing</a>
      <a href="/templates">Templates</a>
      <a href="/marketplace">Marketplace</a>
    </div>
    <div class="footer-column">
      <h4>Resources</h4>
      <a href="/docs">Documentation</a>
      <a href="/blog">Blog</a>
      <a href="/help">Help Center</a>
      <a href="/api">API Reference</a>
    </div>
    <div class="footer-column">
      <h4>Company</h4>
      <a href="/about">About</a>
      <a href="/careers">Careers</a>
      <a href="/contact">Contact</a>
      <a href="/status">Status</a>
    </div>
  </div>
  <div class="footer-bottom">
    <span>&copy; 2026 SUKIT Inc. All rights reserved.</span>
    <div class="footer-legal">
      <a href="/privacy">Privacy</a>
      <a href="/terms">Terms</a>
      <a href="/cookies">Cookies</a>
    </div>
  </div>
</footer>
`;

